{
  "title": "Go Runtime — Dice App",
  "uid": "goruntime",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Goroutines — backend",
      "targets": [
        { "expr": "go_goroutine_count{job=\"backend\"}", "legendFormat": "goroutines", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Goroutines — frontend",
      "targets": [
        { "expr": "go_goroutine_count{job=\"frontend\"}", "legendFormat": "goroutines", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "GOMAXPROCS — backend",
      "targets": [
        { "expr": "go_processor_limit{job=\"backend\"}", "legendFormat": "procs", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "justifyMode": "center"
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GOGC %",
      "targets": [
        { "expr": "go_config_gogc_percent{job=\"backend\"}", "legendFormat": "GOGC", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "justifyMode": "center"
      },
      "fieldConfig": { "defaults": { "unit": "percent" } },
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "GC Goal (heap target)",
      "targets": [
        { "expr": "go_memory_gc_goal_bytes{job=\"backend\"}", "legendFormat": "gc goal", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "none", "justifyMode": "center"
      },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "Goroutines by Service",
      "targets": [
        { "expr": "go_goroutine_count", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "GC Heap Goal by Service",
      "description": "Target heap size at which the next GC will trigger",
      "targets": [
        { "expr": "go_memory_gc_goal_bytes", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory In-Use — Backend (heap vs stack)",
      "description": "go_memory_used_bytes: 'other' = heap objects + metadata; 'stack' = goroutine stacks",
      "targets": [
        { "expr": "go_memory_used_bytes{job=\"backend\", go_memory_type=\"other\"}", "legendFormat": "heap+meta", "refId": "A" },
        { "expr": "go_memory_used_bytes{job=\"backend\", go_memory_type=\"stack\"}", "legendFormat": "stacks", "refId": "B" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Memory In-Use — Frontend (heap vs stack)",
      "targets": [
        { "expr": "go_memory_used_bytes{job=\"frontend\", go_memory_type=\"other\"}", "legendFormat": "heap+meta", "refId": "A" },
        { "expr": "go_memory_used_bytes{job=\"frontend\", go_memory_type=\"stack\"}", "legendFormat": "stacks", "refId": "B" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2, "fillOpacity": 15 } }
      },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "Allocation Rate — bytes/s",
      "description": "Rate of bytes allocated (freed memory is GC'd separately)",
      "targets": [
        { "expr": "rate(go_memory_allocated_bytes_total[1m])", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Allocation Rate — objects/s",
      "description": "Number of heap objects allocated per second",
      "targets": [
        { "expr": "rate(go_memory_allocations_total[1m])", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 }
    }
  ]
}
