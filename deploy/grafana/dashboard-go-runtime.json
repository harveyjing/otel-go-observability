{
  "title": "Go Runtime — Dice App",
  "uid": "goruntime",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Goroutines (backend)",
      "targets": [
        { "expr": "process_runtime_go_goroutines{job=\"backend\"}", "legendFormat": "goroutines", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      },
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Goroutines (frontend)",
      "targets": [
        { "expr": "process_runtime_go_goroutines{job=\"frontend\"}", "legendFormat": "goroutines", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }
        }
      },
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Heap In-Use (backend)",
      "targets": [
        { "expr": "process_runtime_go_mem_heap_inuse{job=\"backend\"}", "legendFormat": "heap inuse", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "GC Rate (cycles/s)",
      "targets": [
        { "expr": "sum(rate(process_runtime_go_gc_count_total[1m]))", "legendFormat": "gc/s", "refId": "A" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value", "graphMode": "area", "justifyMode": "center"
      },
      "fieldConfig": { "defaults": { "unit": "ops", "decimals": 2 } },
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Goroutines by Service",
      "targets": [
        { "expr": "process_runtime_go_goroutines", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Live Heap Objects by Service",
      "targets": [
        { "expr": "process_runtime_go_mem_live_objects", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Heap Memory — Backend",
      "description": "heap_sys = reserved from OS; heap_inuse = spans with objects; heap_alloc = allocated & live bytes",
      "targets": [
        { "expr": "process_runtime_go_mem_heap_sys{job=\"backend\"}", "legendFormat": "heap_sys", "refId": "A" },
        { "expr": "process_runtime_go_mem_heap_inuse{job=\"backend\"}", "legendFormat": "heap_inuse", "refId": "B" },
        { "expr": "process_runtime_go_mem_heap_alloc{job=\"backend\"}", "legendFormat": "heap_alloc", "refId": "C" },
        { "expr": "process_runtime_go_mem_heap_idle{job=\"backend\"}", "legendFormat": "heap_idle", "refId": "D" },
        { "expr": "process_runtime_go_mem_heap_released{job=\"backend\"}", "legendFormat": "heap_released", "refId": "E" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Heap Memory — Frontend",
      "targets": [
        { "expr": "process_runtime_go_mem_heap_sys{job=\"frontend\"}", "legendFormat": "heap_sys", "refId": "A" },
        { "expr": "process_runtime_go_mem_heap_inuse{job=\"frontend\"}", "legendFormat": "heap_inuse", "refId": "B" },
        { "expr": "process_runtime_go_mem_heap_alloc{job=\"frontend\"}", "legendFormat": "heap_alloc", "refId": "C" },
        { "expr": "process_runtime_go_mem_heap_idle{job=\"frontend\"}", "legendFormat": "heap_idle", "refId": "D" },
        { "expr": "process_runtime_go_mem_heap_released{job=\"frontend\"}", "legendFormat": "heap_released", "refId": "E" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "GC Cycles Rate (cycles/s)",
      "targets": [
        { "expr": "rate(process_runtime_go_gc_count_total[1m])", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "GC Pause Time Rate (ns/s)",
      "description": "Rate of nanoseconds spent in GC pauses — proxy for GC pressure",
      "targets": [
        { "expr": "rate(process_runtime_go_gc_pause_total_ns_total[1m])", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ns", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Memory Allocation Rate (bytes/s)",
      "description": "Rate of heap_alloc growth — how fast the app allocates memory",
      "targets": [
        { "expr": "rate(process_runtime_go_mem_heap_alloc{job=\"backend\"}[1m])", "legendFormat": "backend alloc rate", "refId": "A" },
        { "expr": "rate(process_runtime_go_mem_heap_alloc{job=\"frontend\"}[1m])", "legendFormat": "frontend alloc rate", "refId": "B" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "x": 0, "y": 28, "w": 12, "h": 8 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "CGO Calls Rate (calls/s)",
      "targets": [
        { "expr": "rate(process_runtime_go_cgo_calls_total[1m])", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "gridPos": { "x": 12, "y": 28, "w": 12, "h": 8 }
    }
  ]
}
